            ],
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nuevo Usuario\",\n  \"username\": \"usuario_nuevo@test.com\",\n  \"password\": \"clave123\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "2 - Listar usuarios",
