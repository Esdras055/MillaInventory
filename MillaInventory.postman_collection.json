    {
      "name": "Gestion de autenticacion",
      "item": [
        {
          "name": "1 - Login (obtener JWT)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"farid@test.com\",\n  \"password\": \"prueba1\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
