  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [],
        "type": "text/javascript"
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [
          "if (pm.response.code === 200 && pm.request.url.path.includes('auth/login')) {",
          "    var jsonData = pm.response.json();",
          "    pm.collectionVariables.set('jwtToken', jsonData.token);",
          "}",
          "",
          "if (pm.response.code === 201 && pm.request.url.path.includes('users')) {",
          "    var userData = pm.response.json();",
          "    pm.collectionVariables.set('userId', userData.id);",
          "}",
          "",
          "if (pm.response.code === 201 && pm.request.url.path.includes('ubicaciones')) {",
          "    var ubicacionData = pm.response.json();",
          "    pm.collectionVariables.set('ubicacionId', ubicacionData.id);",
          "}",
          "",
          "if (pm.response.code === 201 && pm.request.url.path.includes('categorias')) {",
          "    var categoriaData = pm.response.json();",
          "    pm.collectionVariables.set('categoriaId', categoriaData.id);",
          "}",
          "",
          "if (pm.response.code === 201 && pm.request.url.path.includes('marcas')) {",
          "    var marcaData = pm.response.json();",
          "    pm.collectionVariables.set('marcaId', marcaData.id);",
          "}",
          "",
          "if (pm.response.code === 201 && pm.request.url.path.includes('bodegas')) {",
          "    var bodegaData = pm.response.json();",
          "    pm.collectionVariables.set('bodegaId', bodegaData.id);",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "jwtToken", "value": "" },
    { "key": "userId", "value": "1" },
    { "key": "ubicacionId", "value": "1" },
    { "key": "categoriaId", "value": "1" },
    { "key": "marcaId", "value": "1" },
    { "key": "bodegaId", "value": "1" }
  ]
}
